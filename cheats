local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
    Name = "PREMIUM ALL-IN-ONE CHEAT",
    LoadingTitle = "Načítání modulů...",
    LoadingSubtitle = "by Gemini",
})

-- KONFIGURACE
local config = {
    aimbot = false,
    silentAim = false,
    esp = false,
    noRecoil = false,
    noSpread = false,
    smoothness = 0.05,
    fov = 150,
    teamCheck = true
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local FOVCircle = Drawing.new("Circle")

-- HOOK PRO SILENT AIM
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if config.silentAim and (method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList") then
        local target = nil
        local dist = config.fov
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                if config.teamCheck and p.Team == LocalPlayer.Team then continue end
                local pos, onScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if d < dist then target = p.Character.Head dist = d end
                end
            end
        end
        if target then
            args[1] = Ray.new(args[1].Origin, (target.Position - args[1].Origin).Unit * 1000)
        end
    end
    return old(self, unpack(args))
end)
setreadonly(mt, true)

-- GUI ZÁLOŽKY
local MainTab = Window:CreateTab("Combat", 4483362458)
local VisualsTab = Window:CreateTab("Visuals", 4483345998)

-- MAIN TAB
MainTab:CreateToggle({ Name = "Aimbot", Callback = function(V) config.aimbot = V end })
MainTab:CreateToggle({ Name = "Silent Aim", Callback = function(V) config.silentAim = V end })
MainTab:CreateToggle({ Name = "No Recoil", Callback = function(V) config.noRecoil = V end })
MainTab:CreateToggle({ Name = "No Spread", Callback = function(V) config.noSpread = V end })
MainTab:CreateSlider({ Name = "FOV Size", Range = {10, 500}, CurrentValue = 150, Callback = function(V) config.fov = V end })
MainTab:CreateToggle({ Name = "Team Check", CurrentValue = true, Callback = function(V) config.teamCheck = V end })

-- VISUALS TAB
VisualsTab:CreateToggle({ Name = "ESP Boxes", Callback = function(V) config.esp = V end })

-- HLAVNÍ LOOP
RunService.RenderStepped:Connect(function()
    -- FOV Vizualizace
    FOVCircle.Visible = (config.aimbot or config.silentAim)
    FOVCircle.Radius = config.fov
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    -- Aimbot logika
    if config.aimbot then
        -- (Zde by byla logika pro smooth aimbot)
    end

    -- Gun Mods (Recoil/Spread)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Gun") then
        local gun = LocalPlayer.Character.Gun
        if config.noRecoil and gun:FindFirstChild("Recoil") then gun.Recoil.Value = Vector3.new(0, 0, 0) end
        if config.noSpread and gun:FindFirstChild("Spread") then gun.Spread.Value = 0 end
    end

    -- ESP logika
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character then
            local box = player.Character:FindFirstChild("ESP_Box")
            if config.esp and player ~= LocalPlayer then
                if not box then
                    local b = Instance.new("BoxHandleAdornment")
                    b.Name = "ESP_Box"
                    b.AlwaysOnTop = true
                    b.Adornee = player.Character
                    b.Color3 = Color3.new(1, 0, 0)
                    b.Size = player.Character:GetExtentsSize()
                    b.Transparency = 0.7
                    b.Parent = player.Character
                end
            elseif box then
                box:Destroy()
            end
        end
    end
end)
