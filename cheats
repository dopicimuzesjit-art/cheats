local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local Window = Rayfield:CreateWindow({
    Name = "Custom Cheat Menu",
    LoadingTitle = "Načítání...",
    LoadingSubtitle = "by Gemini",
    ConfigurationSaving = { Enabled = true, FolderName = "GeminiCheats", FileName = "Config" }
})

local config = {
    aimbot = false, silentAim = false, esp = false,
    smoothness = 0.1, aimFOV = 150, teamCheck = true
}

-- FUNKCE PRO HLEDÁNÍ CÍLE
local function getClosestPlayer(maxFOV)
    local closest = nil
    local shortestDistance = maxFOV

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            if config.teamCheck and player.Team == LocalPlayer.Team then continue end
            
            local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if distance < shortestDistance then
                    closest = player.Character.HumanoidRootPart
                    shortestDistance = distance
                end
            end
        end
    end
    return closest
end

-- ZÁLOŽKA MAIN
local MainTab = Window:CreateTab("Main", 4483362458)
MainTab:CreateToggle({Name = "Aimbot", Callback = function(v) config.aimbot = v end})
MainTab:CreateToggle({Name = "Silent Aim", Callback = function(v) config.silentAim = v end})
MainTab:CreateSlider({Name = "Smoothness", Range = {0.01, 1}, Increment = 0.05, CurrentValue = 0.1, Callback = function(v) config.smoothness = v end})

-- HLAVNÍ LOOP
RunService.RenderStepped:Connect(function(dt)
    local target = getClosestPlayer(config.aimFOV)

    -- AIMBOT (Plynulé míření)
    if target and config.aimbot then
        local lookCFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
        Camera.CFrame = Camera.CFrame:Lerp(lookCFrame, config.smoothness * (dt * 60))
    end

    -- SILENT AIM (Okamžitý snap při stisku)
    if target and config.silentAim and UserInputService:IsMouseButtonDown(Enum.UserInputType.MouseButton1) then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
    end

    -- OPTIMALIZOVANÉ ESP
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local box = player.Character:FindFirstChild("ESP_Box")
            if config.esp then
                if not box then
                    box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESP_Box"
                    box.AlwaysOnTop = true
                    box.Adornee = player.Character
                    box.Parent = player.Character
                end
                box.Size = player.Character:GetExtentsSize()
                box.Color3 = (player.Team == LocalPlayer.Team) and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
            elseif box then
                box:Destroy()
            end
        end
    end
end)
