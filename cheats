})



VisualTab:CreateToggle({

Name = "Team Check",

CurrentValue = true,

Callback = function(Value) config.teamCheck = Value end,

})



-- HLAVNÍ LOOP

game:GetService("RunService").RenderStepped:Connect(function()

local target = getClosestPlayer(math.max(config.aimFOV, config.silentFOV))



if target then

-- AIMBOT (Snap)

if config.aimbot then

Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, target.Position), config.smoothness)

end



-- SILENT AIM (Při kliknutí)

if config.silentAim and game:GetService("UserInputService"):IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then

Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)

end

end



-- JEDNODUCHÉ ESP

for _, player in pairs(Players:GetPlayers()) do

if player ~= LocalPlayer and player.Character then

local box = player.Character:FindFirstChild("ESP_Box")

if config.esp then

if not box then

local b = Instance.new("BoxHandleAdornment")

b.Name = "ESP_Box"

b.AlwaysOnTop = true

b.Adornee = player.Character

b.Color3 = (player.Team == LocalPlayer.Team) and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)

b.Size = player.Character:GetExtentsSize()

b.Transparency = 0.7

b.Parent = player.Character

end

elseif box then

box:Destroy()

end

end

end

end)



