-- KONFIGURACE
local config = { silentAim = false, noRecoil = false, noSpread = false, fov = 150, teamCheck = true }
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- SILENT AIM & RECOIL HOOK
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    -- Silent Aim (přesměrování střelby)
    if config.silentAim and (method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList") then
        local target = nil
        local dist = config.fov
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                if config.teamCheck and p.Team == LocalPlayer.Team then continue end
                local pos, onScreen = Camera:WorldToViewportPoint(p.Character.Head.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if d < dist then target = p.Character.Head dist = d end
                end
            end
        end
        if target then
            args[1] = Ray.new(args[1].Origin, (target.Position - args[1].Origin).Unit * 1000)
        end
    end
    return old(self, unpack(args))
end)
setreadonly(mt, true)

-- NO RECOIL / SPREAD (Hook na zbraň)
game:GetService("RunService").RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Gun") then
        local gun = LocalPlayer.Character.Gun
        if config.noRecoil then
            gun.Recoil.Value = Vector3.new(0, 0, 0) -- Vynulování zpětného rázu
        end
        if config.noSpread then
            gun.Spread.Value = 0 -- Vynulování rozptylu
        end
    end
end)

