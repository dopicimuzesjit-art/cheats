-- GLOBÁLNÍ KONFIGURACE
local config = {
   aimbot = false,
   silentAim = false,
   esp = false,
   noRecoil = false,
   noSpread = false,
   teamCheck = true,
   smoothness = 0.1,
   fov = 150
}

